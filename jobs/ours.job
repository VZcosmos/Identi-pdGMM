#!/bin/bash
#SBATCH --partition=gpu_a100
#SBATCH --gpus=1
#SBATCH --job-name=ours
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --time=72:00:00
#SBATCH --array=0-1%2
#SBATCH --output=logs/ours_%A_%a.out

module purge
module load 2025
module load Anaconda3/2025.06-1

source activate expo
cd /home/xzhou2/Identi-pdGMM
export WANDB_API_KEY=
echo "job=$SLURM_JOB_ID array_task=$SLURM_ARRAY_TASK_ID"
echo "node=$(hostname)"
echo "CUDA_VISIBLE_DEVICES=$CUDA_VISIBLE_DEVICES"
nvidia-smi

SEEDS=(137 520 1049 2027 3187) #4441 5821 6967 8111 9901

