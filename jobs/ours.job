0)
  for SEED in "${SEEDS[@]}"; do
    echo "Running ours_simple gauss seed=$SEED"
    srun python ours_simple.py --seeds $SEED \
      --noise-type gauss \
      --lr_redu_linear 1e-4 --lr 1e-4 \
      --sparse-level 0.01 \
      --n-steps 100001 --n-steps-redulinear 10001 \
      --batch-size 6144 \
      --noise_scale 1 \
      --z-n 3 --x-n 3 --nn 3 \
      --mask-dense 1 --n-mixing-layer 1 --mask-size 5
  done
  ;;

1)
  for SEED in "${SEEDS[@]}"; do
    echo "Running ours_com gauss seed=$SEED"
    srun python ours_com.py --seeds $SEED \
      --noise-type gauss \
      --lr_redu_linear 1e-4 --lr 1e-4 \
      --sparse-level 0.01 \
      --n-steps 100001 --n-steps-redulinear 10001 \
      --batch-size 6144 \
      --noise_scale 1 \
      --z-n 10 --x-n 10 --nn 10 \
      --mask-dense 50 --n-mixing-layer 10 --mask-size 5
  done
  ;;

